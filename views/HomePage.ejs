<%- include('./Partials/head') %>
<%- include('./Partials/navbar') %>

<main class="flex-grow max-w-7xl mx-auto w-full px-4">
    
    <!-- Header Section -->
    <div class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-4xl font-bold tracking-tight mb-2">Dashboard</h1>
            <p class="text-white/60">
                Welcome back, <span class="text-blue-400 font-semibold capitalize"><%= user ? user.username : 'User' %></span>. Here's your financial overview.
            </p>
        </div>
        <a href="/add-new" class="bg-blue-600/20 text-blue-400 border border-blue-500/30 hover:bg-blue-600 hover:text-white px-5 py-2.5 rounded-xl font-medium transition-all flex items-center gap-2">
            <i class="fa-solid fa-bolt"></i> Quick Log
        </a>
    </div>

    <!-- Category Summary Card -->
    <div class="glass-panel rounded-2xl p-6 mb-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-32 h-32 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 relative z-10">
            <div class="flex items-center gap-3 w-full md:w-auto">
                <div class="w-10 h-10 bg-indigo-500/20 rounded-full flex items-center justify-center border border-indigo-500/30">
                    <i class="fa-solid fa-chart-pie text-indigo-400"></i>
                </div>
                <h3 class="font-semibold text-lg">Category Insights</h3>
            </div>
            
            <div class="flex items-center gap-3 w-full md:w-auto">
                <div class="relative w-full md:w-56">
                    <select id="categorySelect" class="glass-input w-full rounded-xl py-2.5 pl-4 pr-10 appearance-none cursor-pointer text-sm">
                        <option value="" disabled selected>Choose a category...</option>
                        <option value="Food & Dining">Food & Dining</option>
                        <option value="Transportation">Transportation</option>
                        <option value="Utilities">Utilities</option>
                        <option value="Entertainment">Entertainment</option>
                        <option value="Shopping">Shopping</option>
                        <option value="Healthcare">Healthcare</option>
                        <option value="Other">Other</option>
                    </select>
                    <i class="fa-solid fa-chevron-down absolute right-4 top-3.5 text-white/40 pointer-events-none text-xs"></i>
                </div>
                <button id="fetchSummaryBtn" class="bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition-all shadow-lg shadow-indigo-500/30 whitespace-nowrap flex items-center gap-2">
                    <i class="fa-solid fa-calculator"></i> Calculate
                </button>
            </div>
        </div>

        <!-- Hidden Result Display -->
        <div id="summaryResult" class="mt-5 pt-5 border-t border-white/10 hidden relative z-10 transition-all duration-300">
            <div class="flex justify-between items-center bg-black/20 p-5 rounded-xl border border-white/5">
                <div>
                    <p class="text-white/60 text-sm mb-1">Total Spent on <span id="displayCategory" class="text-white font-medium">...</span></p>
                    <p class="text-3xl font-bold text-emerald-400" id="displayTotal">₹ 0.00</p>
                </div>
                <div class="text-right">
                    <p class="text-white/60 text-sm mb-1">Transactions</p>
                    <div class="inline-flex items-center justify-center px-3 py-1 bg-white/10 rounded-lg border border-white/10">
                        <span class="text-xl font-semibold text-white" id="displayCount">0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Expenses List -->
    <div class="glass-panel rounded-2xl overflow-hidden shadow-2xl">
        <div class="px-6 py-5 border-b border-white/10 bg-black/20 flex justify-between items-center">
            <h3 class="font-semibold text-lg"><i class="fa-solid fa-list-ul mr-2 text-white/50"></i> Recent Transactions</h3>
            <span class="text-xs bg-blue-500/20 text-blue-300 px-3 py-1 rounded-full border border-blue-500/20"><%= expenses.length %> Records</span>
        </div>

        <% if (expenses && expenses.length > 0) { %>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead class="text-xs uppercase text-white/50 bg-black/10">
                        <tr>
                            <th class="px-6 py-4 font-medium tracking-wider">Date</th>
                            <th class="px-6 py-4 font-medium tracking-wider">Description</th>
                            <th class="px-6 py-4 font-medium tracking-wider">Category</th>
                            <th class="px-6 py-4 font-medium tracking-wider">Amount</th>
                            <th class="px-6 py-4 font-medium tracking-wider">Receipt</th>
                            <th class="px-6 py-4 font-medium tracking-wider text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% expenses.forEach(function(expense) { %>
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4 text-white/80">
                                    <div class="flex items-center gap-2">
                                        <i class="fa-regular fa-calendar text-white/30"></i>
                                        <%= new Date(expense.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-medium text-white">
                                    <%= expense.expenseName %>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-3 py-1 rounded-full text-xs font-medium bg-indigo-500/20 border border-indigo-500/30 text-indigo-300">
                                        <%= expense.expenseCategory %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 font-semibold text-emerald-400">
                                    ₹ <%= expense.money.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                                </td>
                                <td class="px-6 py-4">
                                    <% if (expense.supportFile && expense.supportFile !== '') { %>
                                        <a href="<%= expense.supportFile %>" target="_blank" class="text-blue-400 hover:text-blue-300 text-xs font-medium flex items-center gap-1 bg-blue-500/10 px-2 py-1 rounded w-max transition">
                                            <% if (expense.supportFileType === 'pdf') { %>
                                                <i class="fa-regular fa-file-pdf"></i> View PDF
                                            <% } else { %>
                                                <i class="fa-regular fa-image"></i> View Image
                                            <% } %>
                                        </a>
                                    <% } else { %>
                                        <span class="text-white/30 text-xs italic">No attachment</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <form action="/delete/<%= expense._id %>" method="POST" class="inline-block" onsubmit="return confirm('Are you sure you want to delete this expense?');">
                                        <button type="submit" class="text-red-400 hover:text-red-300 p-2 rounded-lg hover:bg-red-500/10 transition opacity-0 group-hover:opacity-100 focus:opacity-100">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-12 text-center flex flex-col items-center justify-center">
                <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mb-4">
                    <i class="fa-solid fa-receipt text-3xl text-white/20"></i>
                </div>
                <h3 class="text-xl font-medium text-white mb-2">No expenses recorded yet</h3>
                <p class="text-white/50 mb-6 max-w-md">Your transaction history is empty. Start by logging your first expense to see your data visualized here.</p>
                <a href="/add-new" class="bg-blue-600 hover:bg-blue-500 text-white font-medium py-2.5 px-6 rounded-xl transition shadow-lg shadow-blue-500/20">
                    Create First Entry
                </a>
            </div>
        <% } %>
    </div>
</main>

<script>
    document.getElementById('fetchSummaryBtn').addEventListener('click', async () => {
        const category = document.getElementById('categorySelect').value;
        const resultContainer = document.getElementById('summaryResult');
        
        if (!category) {
            // Shake animation if they don't select anything
            const selectBox = document.getElementById('categorySelect');
            selectBox.classList.add('border-red-500');
            setTimeout(() => selectBox.classList.remove('border-red-500'), 1000);
            return;
        }

        try {
            // Change button icon to spinner
            const btnIcon = document.querySelector('#fetchSummaryBtn i');
            btnIcon.className = 'fa-solid fa-spinner fa-spin';

            // Call your existing backend route
            const response = await fetch(`/summary/${encodeURIComponent(category)}`);
            if (!response.ok) throw new Error('Failed to fetch data');
            
            const data = await response.json();
            
            // Populate the data
            document.getElementById('displayCategory').innerText = data.category;
            document.getElementById('displayTotal').innerText = `₹ ${data.total.toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
            document.getElementById('displayCount').innerText = data.count;
            
            // Reveal the results card smoothly
            resultContainer.classList.remove('hidden');
            
            // Restore button icon
            btnIcon.className = 'fa-solid fa-calculator';

        } catch (error) {
            console.error(error);
            alert('Something went wrong fetching the category summary.');
        }
    });
</script>

<%- include('./Partials/footer') %>
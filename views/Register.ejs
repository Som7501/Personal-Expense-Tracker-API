<%- include('./Partials/head') %>
<%- include('./Partials/navbar') %>

<main class="flex-grow flex items-center justify-center px-4">
    <div class="glass-panel rounded-2xl p-8 w-full max-w-md transform transition-all hover:scale-[1.01]">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-purple-500/20 rounded-full flex items-center justify-center mx-auto mb-4 border border-purple-500/30">
                <i class="fa-solid fa-user-plus text-2xl text-purple-400"></i>
            </div>
            <h1 class="text-3xl font-bold mb-2">Join Us</h1>
            <p class="text-white/60 text-sm">Start tracking your financial journey today</p>
        </div>

        <form action="/register" method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-white/80 mb-1">Username</label>
                <div class="relative">
                    <i class="fa-solid fa-user absolute left-4 top-3.5 text-white/40"></i>
                    <input type="text" name="username" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4" placeholder="johndoe">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-white/80 mb-1">Email Address</label>
                <div class="relative">
                    <i class="fa-solid fa-envelope absolute left-4 top-3.5 text-white/40"></i>
                    <input type="email" name="email" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4" placeholder="you@example.com">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-white/80 mb-1">Password</label>
                <div class="relative">
                    <i class="fa-solid fa-key absolute left-4 top-3.5 text-white/40"></i>
                    <input type="password" name="password" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4" placeholder="Create a strong password">
                </div>
            </div>

            <button type="submit" class="w-full bg-purple-600 hover:bg-purple-500 text-white font-semibold py-3 rounded-xl transition-all shadow-[0_0_15px_rgba(147,51,234,0.4)] hover:shadow-[0_0_25px_rgba(147,51,234,0.6)] mt-4">
                Create Account <i class="fa-solid fa-rocket ml-2"></i>
            </button>
        </form>
        
        <p class="text-center text-sm text-white/60 mt-6">
            Already have an account? <a href="/login" class="text-purple-400 hover:text-purple-300 font-medium">Log in</a>
        </p>
    </div>
</main>

<%- include('./Partials/footer') %>
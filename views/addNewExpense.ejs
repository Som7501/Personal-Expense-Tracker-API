<%- include('./Partials/head') %>
<%- include('./Partials/navbar') %>

<main class="flex-grow max-w-2xl mx-auto w-full px-4">
    <div class="glass-panel rounded-2xl p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="mb-8">
            <h1 class="text-3xl font-bold tracking-tight mb-2">Record Expense</h1>
            <p class="text-white/60">Log a new transaction and attach your receipt.</p>
        </div>

        <form action="/" method="POST" enctype="multipart/form-data" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-1">
                    <label class="text-sm font-medium text-white/80">Description</label>
                    <div class="relative">
                        <i class="fa-solid fa-tag absolute left-4 top-3.5 text-white/40"></i>
                        <input type="text" name="expenseName" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4" placeholder="e.g., Grocery Shopping">
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-sm font-medium text-white/80">Amount (₹)</label>
                    <div class="relative">
                        <i class="fa-solid fa-indian-rupee-sign absolute left-4 top-3.5 text-white/40"></i>
                        <input type="number" step="0.01" min="0" name="money" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4" placeholder="0.00">
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-sm font-medium text-white/80">Category</label>
                    <div class="relative">
                        <i class="fa-solid fa-layer-group absolute left-4 top-3.5 text-white/40"></i>
                        <select name="expenseCategory" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4 appearance-none cursor-pointer">
                            <option value="" disabled selected>Select Category</option>
                            <option value="Food & Dining">Food & Dining</option>
                            <option value="Transportation">Transportation</option>
                            <option value="Utilities">Utilities</option>
                            <option value="Entertainment">Entertainment</option>
                            <option value="Shopping">Shopping</option>
                            <option value="Healthcare">Healthcare</option>
                            <option value="Other">Other</option>
                        </select>
                        <i class="fa-solid fa-chevron-down absolute right-4 top-4 text-white/40 pointer-events-none text-sm"></i>
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-sm font-medium text-white/80">Date</label>
                    <div class="relative">
                        <i class="fa-solid fa-calendar-days absolute left-4 top-3.5 text-white/40"></i>
                        <input type="date" name="date" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4 [color-scheme:dark]">
                    </div>
                </div>
            </div>

            <div class="space-y-1 pt-2">
                <label class="text-sm font-medium text-white/80">Attach Receipt (PDF or Image)</label>
                <div class="flex items-center justify-center w-full">
                    <label class="flex flex-col items-center justify-center w-full h-32 glass-input rounded-xl border-2 border-dashed border-white/20 cursor-pointer hover:bg-white/5 hover:border-blue-400 transition">
                        <div class="flex flex-col items-center justify-center pt-5 pb-6">
                            <i class="fa-solid fa-cloud-arrow-up text-3xl text-blue-400 mb-3"></i>
                            <p class="mb-1 text-sm text-white/70"><span class="font-semibold text-blue-400">Click to upload</span> or drag and drop</p>
                            <p class="text-xs text-white/40">SVG, PNG, JPG or PDF (MAX. 5MB)</p>
                        </div>
                        <input type="file" name="supportFile" class="hidden" accept=".pdf, .jpg, .jpeg, .png, .gif" />
                    </label>
                </div>
            </div>

            <div class="pt-4 border-t border-white/10">
                <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-semibold py-3.5 rounded-xl transition-all shadow-lg hover:shadow-indigo-500/40 flex items-center justify-center gap-2">
                    <i class="fa-solid fa-check-circle"></i> Save Transaction
                </button>
            </div>
        </form>
    </div>
</main>

<%- include('./Partials/footer') %>
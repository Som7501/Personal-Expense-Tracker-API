<%- include('./Partials/head') %>
<%- include('./Partials/navbar') %>

<main class="flex-grow flex items-center justify-center px-4">
    <div class="glass-panel rounded-2xl p-8 w-full max-w-md transform transition-all hover:scale-[1.01]">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-4 border border-blue-500/30">
                <i class="fa-solid fa-user-lock text-2xl text-blue-400"></i>
            </div>
            <h1 class="text-3xl font-bold mb-2">Welcome Back</h1>
            <p class="text-white/60 text-sm">Sign in to manage your expenses</p>
        </div>

        <form action="/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-white/80 mb-1">Email Address</label>
                <div class="relative">
                    <i class="fa-solid fa-envelope absolute left-4 top-3.5 text-white/40"></i>
                    <input type="email" name="email" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4" placeholder="you@example.com">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-white/80 mb-1">Password</label>
                <div class="relative">
                    <i class="fa-solid fa-key absolute left-4 top-3.5 text-white/40"></i>
                    <input type="password" name="password" required class="glass-input w-full rounded-xl py-3 pl-11 pr-4" placeholder="••••••••">
                </div>
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 rounded-xl transition-all shadow-[0_0_15px_rgba(37,99,235,0.4)] hover:shadow-[0_0_25px_rgba(37,99,235,0.6)] mt-4">
                Access Dashboard <i class="fa-solid fa-arrow-right ml-2"></i>
            </button>
        </form>

        <p class="text-center text-sm text-white/60 mt-6">
            Don't have an account? <a href="/register" class="text-blue-400 hover:text-blue-300 font-medium">Create one</a>
        </p>
    </div>
</main>

<%- include('./Partials/footer') %>